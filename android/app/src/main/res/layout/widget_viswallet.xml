<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_brand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vizwallet"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#2DD4BF" />

            <TextView
                android:id="@+id/widget_cycle_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="This cycle"
                android:textSize="10sp"
                android:textColor="#88000000"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_health_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0F3D5E"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Money left"
        android:textSize="10sp"
        android:textColor="#88000000" />

    <TextView
        android:id="@+id/widget_money_left"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₹0"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#0F3D5E"
        android:maxLines="1"
        android:ellipsize="end" />

    <LinearLayout
        android:id="@+id/widget_extended"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textSize="10sp"
                    android:textColor="#88000000" />

                <TextView
                    android:id="@+id/widget_today_spent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#C62828" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Safe daily"
                    android:textSize="10sp"
                    android:textColor="#88000000" />

                <TextView
                    android:id="@+id/widget_safe_daily"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1A6B7A" />
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_budget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:progress="0"
            android:progressTint="#2DD4BF"
            android:progressBackgroundTint="#22000000" />

        <TextView
            android:id="@+id/widget_budget_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Budget"
            android:textSize="10sp"
            android:textColor="#88000000" />

        <LinearLayout
            android:id="@+id/widget_wide_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/widget_subs_line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#88000000"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_bills_line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#88000000"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_full_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent"
                android:textSize="10sp"
                android:textColor="#88000000" />

            <TextView
                android:id="@+id/widget_recent_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#0F3D5E"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_recent_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#C62828" />

            <TextView
                android:id="@+id/widget_wishlist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="9sp"
                android:textColor="#88000000"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_actions_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="end">

        <TextView
            android:id="@+id/widget_btn_calendar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_btn_primary"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Calendar"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/widget_btn_budget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_btn_primary"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Budget"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_btn_health"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_btn_primary"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Health"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_btn_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_btn_primary"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="+ Add"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
